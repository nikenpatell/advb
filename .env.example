# Advocacy SaaS Backend - Production Configuration Environment
# -------------------------------------------------------------------------
# Required variables for proper Vercel operation.

# MongoDB Connection String (Atlas recommended)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database_name

# Port (not needed for Vercel, but for local testing)
PORT=5000

# Environment Mode
NODE_ENV=production

# Security & Tokens
JWT_SECRET=your_super_secure_sha256_secret
JWT_EXPIRES_IN=2d

# Rate Limiting & Performance
# -----------------------------
# Standard limits for production use.
MAX_IP_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=900000 
